{
    // "layer": "top", // Waybar at top layer
    "position": "top", // Waybar position (top|bottom|left|right)
    "height": 30, // Waybar height (to be removed for auto height)
    // "width": 1280, // Waybar width
    // Choose the order of the modules
    "modules-left": ["sway/workspaces", "sway/mode", "custom/media"],
    "modules-center": [""],
    "modules-right": ["network", "pulseaudio", "backlight", "keyboard-state", "battery", "clock", "tray"],
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "tray": {
        "icon-size": 21,
        "spacing": 10
    },
    "clock": {
        "format": "{:%b %d  %H:%M %p}"
    },
    "backlight": {
        // "device": "acpi_video1",
        "format": "LCD | {percent}%",
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "PWR | {capacity}% BAT",
        "format-charging": "PWR | {capacity}% CHR",
        "format-plugged": "PWR | {capacity}% PLG",
    },
    "network": {
        "format-wifi": "NET | {signalStrength}% WiFi",
        "format-ethernet": "NET | ETH",
        "format-linked": "NET | NO IP",
        "format-disconnected": "NET | X",
    },
    "pulseaudio": {
        "format": "VOL | {volume}%",
        "format-muted": "VOL | X",
        //"format-source": "MIC | {volume}%",
        //"format-source-muted": "MIC | X",
    },
}

